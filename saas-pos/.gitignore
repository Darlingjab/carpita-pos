# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Histórico de ventas puede ser >50MB; descomentá si no querés versionar el CSV en Git.
# exports/sales_history_5_years_clean.csv

# Variables locales (no subir a Git). El ejemplo sí se versiona.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
