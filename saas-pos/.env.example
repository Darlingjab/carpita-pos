# === Públicas (pueden ir al bundle del cliente con prefijo NEXT_PUBLIC_) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Zona IANA para reportes / auditoría (opcional).
# NEXT_PUBLIC_BUSINESS_TIMEZONE=America/Guayaquil

# === Solo servidor (Vercel / Node; nunca en el navegador) ===

# Clave secreta para firmar cookies de sesión (HMAC-SHA256).
# Generar en local: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBLIGATORIO en producción; en desarrollo usa una clave fija con advertencia en consola.
SESSION_SECRET=

# Activa lectura/escritura del estado demo en la tabla pos_runtime_state.
SUPABASE_SERVICE_ROLE_KEY=

# === Scripts de importación (local / CI; no suelen ir a Vercel) ===
# Ruta absoluta al CSV/XLSX de ventas si no está en exports/.
# SALES_CSV_PATH=
# SALES_XLSX_PATH=
# Catálogo Excel: por defecto exports/productos 2.xls
# PRODUCTOS_XLS_PATH=
# Fechas sin zona en CSV (Ecuador continental por defecto en sync-exports.cjs).
# IMPORT_SALES_WALL_OFFSET=-05:00
# Límite de ventas en el seed TS (ver sync-exports.cjs).
# IMPORT_SALES_SEED_CAP=20000
# IMPORT_FULL_SALES=1  → incluir todas las ventas en el bundle (muy pesado)
